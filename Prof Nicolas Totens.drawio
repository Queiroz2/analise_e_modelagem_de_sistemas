        <mxCell id="jHD2j_crtFGtrrrA7Afu-15" parent="zLCPgMXPXFrS0N7pDjr4-1" style="rounded=1;whiteSpace=wrap;html=1;" value="Junto a primeira pesquisa, podemos apresentar as opções de cafés, filtrando as opções escolhidas&amp;nbsp;" vertex="1">
