        <mxCell id="jHD2j_crtFGtrrrA7Afu-25" edge="1" parent="zLCPgMXPXFrS0N7pDjr4-1" source="jHD2j_crtFGtrrrA7Afu-22" style="edgeStyle=none;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.75;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;fontSize=12;startSize=8;endSize=8;" target="jHD2j_crtFGtrrrA7Afu-24">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="jHD2j_crtFGtrrrA7Afu-22" parent="zLCPgMXPXFrS0N7pDjr4-1" style="rounded=1;whiteSpace=wrap;html=1;" value="Funções do sistema :&lt;div&gt;&amp;nbsp;&lt;div&gt;Escolher livro&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;pedir café&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Pagar no próprio totem&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Retirar no balcão&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;E por final receber sua senha para retirar seu pedido !!&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="230" width="130" y="400" as="geometry" />
        </mxCell>
        <mxCell id="jHD2j_crtFGtrrrA7Afu-23" edge="1" parent="zLCPgMXPXFrS0N7pDjr4-1" source="jHD2j_crtFGtrrrA7Afu-18" style="edgeStyle=none;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.967;entryY=0.452;entryDx=0;entryDy=0;entryPerimeter=0;fontSize=12;startSize=8;endSize=8;" target="jHD2j_crtFGtrrrA7Afu-22">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="jHD2j_crtFGtrrrA7Afu-28" edge="1" parent="zLCPgMXPXFrS0N7pDjr4-1" source="jHD2j_crtFGtrrrA7Afu-24" style="edgeStyle=none;curved=1;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=12;startSize=8;endSize=8;" target="jHD2j_crtFGtrrrA7Afu-27">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="jHD2j_crtFGtrrrA7Afu-24" parent="zLCPgMXPXFrS0N7pDjr4-1" style="rounded=1;whiteSpace=wrap;html=1;" value="O sistema amplo em escolhas pode proporcionar conforto, já relacionando pedidos anteriores, entregando o mesmo tema mais procurado pelo cliente !" vertex="1">
          <mxGeometry height="160" width="130" x="230" y="520" as="geometry" />
        </mxCell>
        <mxCell id="jHD2j_crtFGtrrrA7Afu-27" parent="zLCPgMXPXFrS0N7pDjr4-1" style="whiteSpace=wrap;html=1;" value="Finalização :&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Esse projeto apresentou o desenvolvimento de um sistema de totens interativos para uma livraria com cafeteria integrada, como objetivo de melhorar a experiência do cliente e tornar o processo de escolhas de livros e pedidos de cafés mais rápido, intuitivo e personalizado.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;A proposta do sistema permite que os clientes utilizem o totem para selecionar livros com base no humor de cada cliente no momento, recebendo recomendações automáticas.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Além disso o sistema sugere opções de cafés que combinam com o estilo de leitura, criando uma experiência diferenciada dentro da livraria. !&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="270" x="40" y="740" as="geometry" />
        </mxCell>
      </root>
